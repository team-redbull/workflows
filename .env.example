# --- Temporal ---
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default

# --- Segments Manager (GETs are public; mutating calls need the bearer token) ---
SEGMENTS_MANAGER_URL=http://localhost:8000
SEGMENTS_MANAGER_API_TOKEN=dev-token

# --- next connectivity service (black box in prod; dev/mock-connectivity locally) ---
NEXT_URL=http://localhost:9000
# URI paths are configurable because the air-gapped prod paths may differ:
NEXT_TOKEN_RENEWAL_URI=/token-renewal-uri
NEXT_OPEN_RULES_URI=/open-rules-uri
NEXT_CHECK_STATUS_URI=/check-request-status

# --- our payload policy (not next's config) ---
DOMAIN=domain1
# Port policy per rule direction — JSON per protocol: {"tcp": ["PORT", "START-END"], "udp": [...]}
# Validated fail-fast at activity-worker startup. In-cluster this comes from the ConfigMap.
PORTS_HC_TO_MCE={"tcp": ["30000-32767"], "udp": ["9000"]}
PORTS_MCE_TO_HC={"tcp": ["6443", "30000-32767"]}
PORTS_INVENTORY_TO_MCE={"tcp": ["30000-32767"], "udp": ["9000"]}
PORTS_MCE_TO_INVENTORY={"tcp": ["6443", "30000-32767"]}
PORTS_PXE_TO_MCE={"tcp": ["30000-32767"], "udp": ["9000"]}
PORTS_MCE_TO_PXE={"tcp": ["6443", "30000-32767"]}

# --- dev/mock-connectivity only: simulated human-approval delay ---
#COMPLETION_DELAY_SECONDS=60
